#!/usr/bin/env ruby
# coding: utf-8
require 'pp'
require 'yaml'
require 'treetop'
require 'json'
require 'cbor-pretty'
require 'cbor-deterministic'

# Temporary fix for name conflicts between cbor-diag and edn-abnf
diag_path = $LOAD_PATH.grep(/gems\/cbor-diag/).first
edn_path = $LOAD_PATH.grep(/gems\/edn-abnf/).first
$LOAD_PATH[$LOAD_PATH.index(diag_path)] = edn_path
$LOAD_PATH << diag_path

require_relative '../lib/edn-abnf.rb'

def snaky(name)
  name.gsub(/-/, "_")
end

class String
  def hexi
    bytes.map{|x| "%02x" % x}.join
  end
  def xeh
    gsub(/\s/, "").chars.each_slice(2).map{ |x| Integer(x.join, 16).chr("BINARY") }.join
  end
end

def tree_from_edn_possibly_hex(s)
  if s[0..1] == "h]"
    s = s[2..-1].xeh.force_encoding(Encoding::UTF_8)
  end
  EDN.from_edn(s).tree
end

Encoding.default_external = Encoding::UTF_8
require 'optparse'
require 'ostruct'

$error = 0

output_formats = [:basic, :neat, :json, :yaml, :edn, :diag, :pretty, :hex, :cbor, :"test-vector"]

$options = OpenStruct.new
begin
  op = OptionParser.new do |opts|
    opts.banner = "Usage: edn-abnf.rb [options] [file.edn... | -]"

    opts.on("-v", "--[no-]verbose", "Run verbosely") do |v|
      $options.verbose = v
    end
    opts.on("-l", "--[no-]lines", "multi-line mode") do |v|
      require 'csv'
      $options.lines = v
    end
    opts.on("-i", "--[no-]integrated", "use integrated parsers where available") do |v|
      $options.integrated = v
    end
    opts.on("--[no-]level", "use separate level shifter") do |v|
      $options.level = v
      $stdout.sync = true
    end
    opts.on("-eEDN", "--e=EDN", "supply EDN on command line") do |v|
      $options.edn = v
    end
    opts.on("-c", "--[no-]cbor", "input is encoded CBOR data item, not EDN") do |v|
      $options.cbor = v
    end
    opts.on("-tFMT", "--to=FMT",
            output_formats,
            "Target format (#{output_formats.join("/")}, default: diag)") do |v|
      $options.target = v
    end
    opts.on("-aAPP", "--app=APP", "Load application extension") do |v|
      v.split(",") do |nm|
        if nm =~ /\A[a-z][a-z0-9]*\z/
          require "cbor-diagnostic-app/#{nm}"
        else
          raise ArgumentError.new("edn-abnf: app-extension name #{nm} not installed")
        end
      end
    end
    opts.on("-f", "--[no-]fallback", "use tag 999 for unknown app-extensions") do |v|
      $options.fallback = v
    end
  end
  op.parse!
rescue Exception => e
  warn e
  warn op
  exit 1
end

if !$options.edn
  ARGF.binmode if $options.cbor
  $options.edn = ARGF.read
else
  if ARGV != []
    warn "*** file names #{ARGV.join(", ")} ignored due to -e given"
  end
end

edn_file = $options.edn

if $options.lines
  if $options.cbor
    warn "*** -l and -c don't combine"
    exit 1
  end
  CSV.parse(edn_file) do |ok, ednin, out|
    if ok[0] == "#"
      puts "# #{ok}, #{ednin.inspect}, #{out}" if $options.verbose
      next
    end
    if ok[0] == "x"
      result = tree_from_edn_possibly_hex(ednin)
      result_hex = result.to_cbor.hexi
      result_diag = result.cbor_diagnostic
      puts "x #{ok}, #{ednin.inspect} / #{out} ➔ #{result_diag.inspect} / #{result_hex}" if $options.verbose
      if result_hex != out
        if  CBOR.decode(out.xeh).to_cbor == result.to_cbor
          puts "** x variant / #{ednin.inspect} / #{out} ≠ #{result_diag.inspect} / #{result_hex}"
        else
          puts "** x / #{ednin.inspect} / #{out} ≠ #{result_diag.inspect} / #{result_hex}"
        end
        $error += 1
      end
      next
    end
    begin
      ok = ok == "="
      puts "➔ #{ok}, #{ednin}, #{out}" if $options.verbose
      result = tree_from_edn_possibly_hex(ednin)
      diag = result.cbor_diagnostic
      if out == diag && !ok
          puts "** ≠ / #{diag.inspect} / #{out.inspect}"
          $error += 1
      end
      if out != diag && ok
        outdiag = tree_from_edn_possibly_hex(out || "").cbor_diagnostic
        if outdiag != diag
          puts "** ≡ / #{ednin.inspect} #{diag.inspect} / #{out.inspect} #{outdiag.inspect}"
          $error += 1
        end
        puts "reparsed / #{diag.inspect} / #{out.inspect}" if $options.verbose
      end
    rescue ArgumentError => e
      if ok
        puts "** #{e} / #{result.inspect} / #{out.inspect}"
        $error += 1
      else
        if $options.verbose
          puts "expected failure #{e}"
        end
      end
    end
  end
  if $error > 0
    puts
    puts "*** #$error errors!"
    puts
    exit 1
  else
    exit
  end
end

begin
  if $options.cbor
    result = CBOR.decode(edn_file)
  else
    edn = EDN.from_edn(edn_file)
    result = edn.tree               # XXX .tree?
  end
rescue CBOR_DIAG::AppParseError, ArgumentError => e
  puts "** #{e}"
  exit 1
rescue CBOR::OutOfBytesError, RuntimeError, JSON::GeneratorError => e
  puts "** (encoded CBOR input:) #{e}"
  exit 1
end

case $options.target
when :basic
  pp result
when :neat, :json
  require 'neatjson'
  puts JSON.neat_generate(result, after_comma: 1, after_colon: 1)
when :yaml
  puts result.to_yaml
when :edn, :diag, nil
  puts result.cbor_diagnostic
when :pretty, :hex, :cbor
  # XXX can't do Box yet
  enc = if CBOR::Sequence === result
          result.to_cborseq
        else
          result.to_cbor
        end
  case $options.target
  when :pretty
    puts CBOR::pretty_seq(enc)
  when :hex
    puts enc.bytes.map{|x| "%02x" % x}.join
  when :cbor
    $stdout.binmode
    print enc
  else
    fail "Cannot happen"
  end
when :"test-vector"
  fail "Not a map" unless Hash === result
  tests = result.delete("tests")
  fail "tests not an array" unless Array === tests
  failing_tests = result.delete("fail")
  puts result.inspect << ", #{tests.size} tests"
  if failing_tests
    tests.each do |t|
      encoded = t.delete("encoded")
      fail t unless encoded
      begin
        r = CBOR.decode(encoded)
        fail "#{encoded.inspect} unexpectedly decodes, as #{r.cbor_diagnostic}"
      rescue CBOR::OutOfBytesError, RuntimeError, JSON::GeneratorError
        # p [r, t, encoded]
      rescue => e
        puts "*** Unexpected error:"
        p [e, r, t, encoded.hexi]
      end
    end
  else
    tests.each do |t|
      encoded = t.delete("encoded")
      fail t unless encoded
      roundtrip = t.delete("roundtrip") { true } # default is true
      decoded = t.delete("decoded") { :"no-decoded"}
      fail "no decoded" if decoded == :"no-decoded"
      begin
        r = CBOR.decode(encoded)
        if !r.cbor_same?(decoded)
          puts "*** unexpected: decoding #{r.inspect}, expected #{decoded.inspect} in #{t.inspect}"
        end
      rescue => e
        puts "*** decode failure: #{e}"
      end
      if roundtrip
        rt = CBOR.encode(decoded)
        if rt != encoded
          puts "*** unexpected: encoding #{rt.inspect}, expected #{encoded.inspect} in #{t.inspect}"
        end
      end
    end
  end
else
  warn ["Unknown target format: ", $options.target].inspect
end
