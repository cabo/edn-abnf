# Encoding: UTF-8
grammar TESTFORMATGRAMMAR
rule testfile
(record (newline record)* newline?) {def ast;
    [elements[0].ast, *elements[1].elements.map {|el| el.elements[1].ast}].reject{|t| t==[""]} # remove empty lines
end}
end
rule record
(field (COMMA field)*) {def ast;
    [elements[0].ast, *elements[1].elements.map {|el| el.elements[1].ast}]
end}
end
rule field
(escaped / non_escaped)
end
rule escaped
(DQUOTE escaped1* DQUOTE) {def ast;
    elements[1].elements.map {|el|el.ast}.join
end}
end
rule escaped1
(TEXTDATA / COMMA / CR / LF / DQUOTE 2..2 {def ast
'"'
end})
end
rule non_escaped
TEXTDATA*
end
rule COMMA
","
end
rule CR
"\r"
end
rule DQUOTE
"\""
end
rule LF
"\n"
end
rule newline
(CR? LF)
end
rule TEXTDATA
([\ -!] / [\#-\+] / [\--~] / NONASCII)
end
rule NONASCII
([-퟿] / [-􏿿])
end

end
